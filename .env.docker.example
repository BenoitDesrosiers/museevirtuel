APP_NAME=Muse
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ton-domaine.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Base de données MySQL (service Docker "mysql") ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=muse
DB_USERNAME=muse_user
DB_PASSWORD=change_me_in_production

# --- Session / Cache / Queue (database driver) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Mail ---
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ton-domaine.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Vite (build production, pas utilisé au runtime) ---
VITE_APP_NAME="${APP_NAME}"
